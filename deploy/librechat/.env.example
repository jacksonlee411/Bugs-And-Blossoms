# LibreChat runtime baseline env template (DEV-PLAN-232)

# Runtime endpoint used by /assistant-ui proxy and diagnostics.
LIBRECHAT_UPSTREAM=http://127.0.0.1:3080
LIBRECHAT_PORT=3080

# Compose project + data directories.
LIBRECHAT_COMPOSE_PROJECT=bugs-and-blossoms-librechat
# Single source of runtime data root. Relative paths are resolved from repo root.
LIBRECHAT_DATA_ROOT=.local/librechat

# Dependency wiring.
# Current upstream LibreChat backend still hard-requires Mongo for startup.
# The default compose baseline no longer provisions `mongodb`, so point this to an
# externally managed Mongo instance if you need `make assistant-runtime-up` to become healthy.
MONGO_URI=
# These retired platform dependencies must stay blank in the default baseline.
MEILI_HOST=
MEILI_MASTER_KEY=
RAG_API_URL=
VECTOR_DB_PROVIDER=
QDRANT_URL=
RAG_API_VECTOR_DB_TYPE=
RAG_API_ATLAS_MONGO_DB_URI=
RAG_API_ATLAS_SEARCH_INDEX=
RAG_API_COLLECTION_NAME=

# Assistant model runtime config (keep as single-source bridge until DEV-PLAN-233/236 closeout).
ASSISTANT_MODEL_CONFIG_JSON={"provider_routing":{"strategy":"priority_failover","fallback_enabled":false},"providers":[{"name":"openai","enabled":true,"model":"gpt-5-codex","endpoint":"https://api.openai.com/v1","timeout_ms":8000,"retries":1,"priority":10,"key_ref":"OPENAI_API_KEY"}]}
OPENAI_API_KEY=
