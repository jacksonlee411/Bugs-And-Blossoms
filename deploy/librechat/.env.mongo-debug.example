# LibreChat external Mongo debug env
#
# Copy to `deploy/librechat/.env.mongo-debug` when you explicitly need a
# locally runnable upstream backend for debugging. This file is intentionally
# separate from `.env` so the default baseline stays aligned with DEV-PLAN-360A.

# Use a separate project / port so debug mode cannot silently collide with the
# default runtime baseline.
LIBRECHAT_UPSTREAM=http://127.0.0.1:3081
LIBRECHAT_PORT=3081
LIBRECHAT_COMPOSE_PROJECT=bugs-and-blossoms-librechat-mongo-debug
LIBRECHAT_DATA_ROOT=.local/librechat-mongo-debug

# Required: current upstream LibreChat backend will not boot without Mongo.
MONGO_URI=

# Keep retired platform dependencies blank even in mongo-debug mode unless you
# are intentionally debugging those historical capabilities in a private patch.
MEILI_HOST=
MEILI_MASTER_KEY=
RAG_API_URL=
VECTOR_DB_PROVIDER=
QDRANT_URL=
RAG_API_VECTOR_DB_TYPE=
RAG_API_ATLAS_MONGO_DB_URI=
RAG_API_ATLAS_SEARCH_INDEX=
RAG_API_COLLECTION_NAME=

# Assistant model runtime config.
ASSISTANT_MODEL_CONFIG_JSON={"provider_routing":{"strategy":"priority_failover","fallback_enabled":false},"providers":[{"name":"openai","enabled":true,"model":"gpt-5-codex","endpoint":"https://api.openai.com/v1","timeout_ms":8000,"retries":1,"priority":10,"key_ref":"OPENAI_API_KEY"}]}
OPENAI_API_KEY=
